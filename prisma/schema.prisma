// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model GlobalConfig {
  id              String   @id @default("global") @map("_id")
  maintenanceMode Boolean  @default(false)
  updatedAt       DateTime @updatedAt
}

model BotConfig {
  id           String  @id @default(auto()) @map("_id") @db.ObjectId
  name         String
  token        String
  prefix       String
  clientId     String  @unique
  status       String? @default("online")
  activity     String? @default("Lavamusic")
  activityType Int?    @default(0)
  active       Boolean @default(true)

  // New relation: one bot can have many prefixes in many guilds
  guildConfigs GuildBotConfig[] @relation("BotClientConfig")
  stays        Stay[]
}

model Bot {
  botId         String @id @map("_id")
  totalPlaySong Int
}

model Guild {
  guildId  String  @id @map("_id")
  language String? @default("Vietnamese")
  stay     Stay[]
  dj       Dj?
  roles    Role[]
  setup    Setup?

  // New relation: one guild can have many bot-prefix mappings
  botConfigs GuildBotConfig[]

  // Statistics relations
  playbackSessions PlaybackSession[]
  hourlyStats      HourlyStats[]
  commandUsage     CommandUsage[]
  trackPlays       TrackPlay[]
}

model GuildBotConfig {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  guildId     String
  botClientId String
  prefix      String

  Guild     Guild     @relation(fields: [guildId], references: [guildId])
  BotConfig BotConfig @relation("BotClientConfig", fields: [botClientId], references: [clientId])

  @@unique([guildId, botClientId]) // ensures one bot per guild has one prefix
}

model Stay {
  id          String @id @default(auto()) @map("_id") @db.ObjectId
  guildId     String
  botClientId String
  textId      String
  voiceId     String

  Guild     Guild     @relation(fields: [guildId], references: [guildId])
  BotConfig BotConfig @relation(fields: [botClientId], references: [clientId])

  @@unique([guildId, botClientId])
}

model Dj {
  guildId String  @id @map("_id")
  mode    Boolean
  Guild   Guild   @relation(fields: [guildId], references: [guildId])
}

model Role {
  guildId String @id @map("_id")
  roleId  String
  Guild   Guild  @relation(fields: [guildId], references: [guildId])

  @@unique([guildId, roleId])
}

model Playlist {
  id     String  @id @default(uuid()) @map("_id")
  userId String
  name   String
  tracks String? // Store the array of encoded tracks as a JSON string

  @@unique([userId, name])
}

model Setup {
  guildId   String @id @map("_id")
  textId    String
  messageId String
  Guild     Guild  @relation(fields: [guildId], references: [guildId])
}

model PlayerState {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId               String
  botClientId           String
  voiceChannelId        String
  textChannelId         String
  nodeId                String
  selfDeaf              Boolean
  selfMute              Boolean
  applyVolumeAsFilter   Boolean  @default(false)
  instaUpdateFiltersFix Boolean  @default(false)
  vcRegion              String
  updatedAt             DateTime @updatedAt

  @@unique([guildId, botClientId])
}

model GuildBotPreferences {
  guildId      String   @id @map("_id")
  botClientIds String[]
  updatedAt    DateTime @updatedAt
}

model DashboardUser {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  discordId String   @unique
  username  String
  avatar    String?
  role      String   @default("user") // owner, admin, moderator, user
  createdAt DateTime @default(now())
  lastLogin DateTime @updatedAt

  // Permissions
  managedBots   String[] // clientIds user can manage
  sessions      DashboardSession[]
  auditLogs     AuditLog[]
  apiKeys       ApiKey[]
  blockedTracks BlockedTrack[]
}

model DashboardSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?

  user DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  action    String // bot.create, bot.delete, player.skip, etc.
  target    String // clientId, guildId, etc.
  metadata  Json? // Additional context
  timestamp DateTime @default(now())

  user DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model BotStats {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  clientId    String
  timestamp   DateTime @default(now())
  guildCount  Int
  playerCount Int
  totalPlays  Int
  uptime      Int // seconds
  memory      Float // MB
  cpu         Float // percentage
  latency     Int // ms

  @@index([clientId, timestamp])
}

model PlayerHistory {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId    String
  clientId   String
  trackUrl   String
  trackTitle String
  author     String?  // Username who requested
  authorId   String?  // User ID who requested
  playedAt   DateTime @default(now())
  duration   Int // Track duration in ms

  @@index([guildId, playedAt])
  @@index([clientId, playedAt])
}

model ApiKey {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  key         String    @unique
  name        String
  userId      String    @db.ObjectId
  permissions String[] // Array of permission strings
  rateLimit   Int       @default(100) // requests per minute
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())
  lastUsed    DateTime?
  usageCount  Int       @default(0)

  user DashboardUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model BlockedTrack {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  uri       String
  title     String?
  reason    String
  blockedBy String   @db.ObjectId // User ID who blocked it
  blockedAt DateTime @default(now())
  scope     String // "global", "guild", or "bot"
  scopeId   String? // Guild ID or Bot Client ID

  user DashboardUser @relation(fields: [blockedBy], references: [id], onDelete: Cascade)

  @@unique([uri, scope, scopeId])
  @@index([scope, scopeId])
}

// Track individual playback sessions
model PlaybackSession {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  guildId       String
  botId         String
  startedAt     DateTime  @default(now())
  endedAt       DateTime?
  duration      Int // in seconds
  listenerCount Int       @default(0)
  source        String // youtube, spotify, soundcloud
  trackName     String?
  trackUrl      String?
  createdAt     DateTime  @default(now())

  guild Guild @relation(fields: [guildId], references: [guildId])

  @@index([guildId, startedAt])
  @@index([botId, startedAt])
}

// Aggregated hourly statistics for efficient querying
model HourlyStats {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId         String
  botId           String
  hour            DateTime // Truncated to hour
  sessionCount    Int      @default(0)
  totalDuration   Int      @default(0) // in seconds
  avgListeners    Float    @default(0)
  maxListeners    Int      @default(0)
  minListeners    Int      @default(0)
  youtubePlays    Int      @default(0)
  spotifyPlays    Int      @default(0)
  soundcloudPlays Int      @default(0)
  createdAt       DateTime @default(now())

  guild Guild @relation(fields: [guildId], references: [guildId])

  @@unique([guildId, botId, hour])
  @@index([guildId, hour])
}

// Track command usage
model CommandUsage {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  guildId     String
  botId       String
  commandName String
  usedAt      DateTime @default(now())
  userId      String

  guild Guild @relation(fields: [guildId], references: [guildId])

  @@index([guildId, usedAt])
  @@index([commandName])
}

// Track user donations for premium features
model UserDonation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String
  amount    Float // in USD
  currency  String   @default("USD")
  donatedAt DateTime @default(now())
  source    String? // paypal, patreon, etc.

  @@index([userId])
}

// Track most played tracks
model TrackPlay {
  id            String    @id @default(auto()) @map("_id") @db.ObjectId
  guildId       String
  botId         String
  trackName     String
  trackUrl      String
  source        String // youtube, spotify, soundcloud
  duration      Int // in seconds
  startedAt     DateTime  @default(now())
  endedAt       DateTime? // When the track finished/stopped
  playedBy      String // user who requested
  listenerCount Int       @default(0) // Number of listeners when track started/ended
  // Unique identifier for upsert: guildId + botId + trackUrl + startedAt (rounded to second)
  trackPlayId   String? // Optional unique ID, uses original MongoDB ObjectId for uniqueness

  guild Guild @relation(fields: [guildId], references: [guildId])

  @@index([guildId, startedAt])
  @@index([trackUrl])
  @@index([botId, startedAt])
}

// Temporary Recurring Announcements
// Time-limited announcements that recur at specified intervals and automatically expire
model TemporaryAnnouncement {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  title          String                      // Embed title
  description    String                      // Embed description
  color          String?   @default("5865F2") // Hex color code (optional, default: Discord blurple)

  // Timing Configuration
  intervalMs     Int       @default(1800000)  // Recurrence interval in ms (default: 30 min)
  expiresAt      DateTime                    // When announcement stops being active

  // State Management
  isActive       Boolean   @default(true)     // Can be manually disabled
  lastSentAt     DateTime?                   // Track last send time

  // Metadata
  createdAt      DateTime  @default(now())
  createdBy      String                      // Discord user ID of creator
  createdByName  String?                     // Username for display purposes

  // Statistics
  sendCount      Int       @default(0)        // Number of times sent

  @@index([isActive, expiresAt])
  @@index([lastSentAt])
}
